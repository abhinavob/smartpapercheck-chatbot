# Copy to .env and fill in values. .env is git-ignored; never commit real secrets.
# Loaded into the Settings object (app/core/config.py) via pydantic-settings.

# ---- App ----
ENVIRONMENT=local
# Comma-separated list of allowed CORS origins (the frontend dev server, etc.).
CORS_ALLOW_ORIGINS=http://localhost:5173

# ---- Database ----
# Local dev points at the Docker Postgres from docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://spc:spc_dev_pw@localhost:5432/spc_chatbot
# Staging/prod (Supabase): DATABASE_URL is the POOLED connection (port 6543);
# DIRECT_URL is the direct connection (port 5432), used only for Alembic migrations.
# Leave DIRECT_URL unset locally — migrations then use DATABASE_URL.
# DIRECT_URL=

# ---- Claude API (added in the AI slice) ----
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-fable-5

# ---- Voyage embeddings (added in the RAG slice) ----
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-4-lite

# ---- Brevo email (added in the email slice) ----
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=SmartPaperCheck
# SUPPORT_TEAM_EMAIL=
