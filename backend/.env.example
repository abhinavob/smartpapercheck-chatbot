# Copy to .env and fill in real values. .env is git-ignored; this template is committed.
# Loaded into the Settings object (config.py) via pydantic-settings.
# Settings rejects unknown variables — do not add keys that config.py does not declare.

# ---- Supabase (Postgres + pgvector) ----
# Project URL and service-role key: Supabase dashboard -> Settings -> API.
# The service-role key bypasses row-level security. Server-side only; never ship it to a browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Claude ----
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

# ---- Voyage embeddings ----
# Must stay on a 1024-dimension model to match vector(1024) in the database schema.
VOYAGE_API_KEY=

# ---- Brevo email ----
# SENDER_EMAIL must be a sender address verified in Brevo, or delivery fails.
# ADMIN_EMAIL receives new-lead and support-query notifications.
BREVO_API_KEY=
SENDER_EMAIL=
ADMIN_EMAIL=

# ---- Chatbot target ----
# The single website the bot scrapes and answers questions about.
WEBSITE_URL=
