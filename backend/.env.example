# Copy to .env and fill in real values. .env is gitignored; this template is committed.
# Settings are loaded from these env vars via pydantic-settings (app/core/config.py).

# ---- Database ----
# Async driver (asyncpg) for the app. Matches docker-compose.yml dev credentials.
DATABASE_URL=postgresql+asyncpg://spc:spc_dev_pw@localhost:5432/spc_chatbot

# ---- Claude API (added in the AI slice) ----
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-fable-5

# ---- Brevo email (added in the email slice) ----
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=SmartPaperCheck
# SUPPORT_TEAM_EMAIL=

# ---- App ----
# Comma-separated allowed origins for CORS (the frontend dev server, etc.)
CORS_ALLOW_ORIGINS=http://localhost:5173
